FLASK_ENV=development
SECRET_KEY=
JWT_SECRET_KEY=
DATABASE_URL=
APP_BASE_URL=http://rnw.com

MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@roomnearwork.local

REDIS_URL=redis://redis:6379/0
RATELIMIT_STORAGE_URI=redis://redis:6379/1
CACHE_TYPE=SimpleCache

GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_REGION=ZA
GOOGLE_MAPS_LANGUAGE=en-ZA
GOOGLE_ROUTE_MATRIX_ENABLED=true
DEFAULT_SEARCH_RADIUS_KM=20
DEFAULT_MAX_TRAVEL_MINUTES=45

PAYMENT_PROVIDER=enable
PAYFAST_SANDBOX=False
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

TENANT_MONTHLY_PRICE=50
TENANT_MAX_RENTAL_APPLICATIONS = 10
LANDLORD_MONTHLY_PRICE=100
LANDLORD_MAX_LISTINGS=25
SUBSCRIPTION_CURRENCY=ZAR

EMAIL_VERIFICATION_REQUIRED=True
ADMIN_2FA_REQUIRED=True
LISTING_EXPIRES_DAYS=30
SAVED_SEARCH_ALERTS_ENABLED=true
RUN_JOBS_INLINE=true
MAX_UPLOAD_MB=12
UPLOAD_STORAGE_BACKEND=local


PROXY_FIX_ENABLED=true
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
SESSION_COOKIE_SECURE=true
REMEMBER_COOKIE_SECURE=true
LOG_LEVEL=INFO
LOG_FILE=/var/data/logs/rnw.log
