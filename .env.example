# RNW environment
FLASK_APP=backend.app:create_app
FLASK_ENV=development
APP_NAME=RNW
APP_BASE_URL=http://localhost:5000
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# Database
DATABASE_URL=sqlite:///backend/instance/rnw.sqlite3
# Production MySQL example:
# DATABASE_URL=mysql+pymysql://rnw:${MYSQL_PASSWORD}@db:3306/rnw
# Production PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://rnw:${POSTGRES_PASSWORD}@db:5432/rnw

# Mail
MAIL_SERVER=localhost
MAIL_PORT=25
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@rnw.local
EMAIL_VERIFICATION_REQUIRED=false

# Cache / rate limiting
REDIS_URL=redis://redis:6379/0
CACHE_TYPE=SimpleCache
RATELIMIT_STORAGE_URI=memory://

# Uploads and logs
UPLOAD_FOLDER=backend/instance/uploads
MAX_CONTENT_LENGTH_MB=16
LOG_LEVEL=INFO
LOG_FILE=backend/instance/logs/rnw.log

# Billing prices and limits — change these, then run: flask --app backend.app:create_app ensure-plans
PAYMENT_PROVIDER=disabled
TENANT_MONTHLY_PRICE=50
LANDLORD_MONTHLY_PRICE=100
LANDLORD_MAX_LISTINGS=25
SUBSCRIPTION_CURRENCY=ZAR

# PayFast — use only when PAYMENT_PROVIDER=payfast
PAYFAST_SANDBOX=true
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

# Stripe placeholders are kept for future work; Stripe checkout is not implemented in this build.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Docker database secrets
MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_DATABASE=rnw
MYSQL_USER=rnw
MYSQL_PASSWORD=change-db-password

# Production launch settings — uncomment/edit for production only
# APP_BASE_URL=https://your-domain.co.za
SUPPORT_EMAIL=support@your-domain.co.za
LEGAL_VERSION=2026-06
AUTO_INIT_DB=true
SEED_DEMO_DATA=false

# Storage: local, cloudinary, s3, or spaces
STORAGE_PROVIDER=local
CLOUDINARY_URL=
CLOUDINARY_DELIVERY_BASE=
PUBLIC_STORAGE_BASE_URL=
S3_BUCKET=
S3_REGION=af-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# PayFast production checklist
# PAYMENT_PROVIDER=payfast
# PAYFAST_SANDBOX=false
# PAYFAST_MERCHANT_ID=
# PAYFAST_MERCHANT_KEY=
# PAYFAST_PASSPHRASE=
