FLASK_ENV=development
SECRET_KEY=dev-only-change-before-production
JWT_SECRET_KEY=dev-only-change-jwt-before-production
DATABASE_URL=sqlite:///rnw_dev.sqlite3
APP_BASE_URL=http://localhost:5000

MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@roomnearwork.local

# Local development defaults. Docker Compose overrides these to use the redis service.
REDIS_URL=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=memory://
CACHE_TYPE=SimpleCache
TENANT_MAX_RENTAL_APPLICATIONS = 10

# Google Maps Platform. Enable Geocoding API, Places API, and Routes API.
# GOOGLE_MAPS_API_KEY is used server-side. GOOGLE_MAPS_BROWSER_KEY is optional for browser maps/autocomplete.
# When blank, RNW uses demo-safe South African fallback coordinates for local development.
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_REGION=ZA
GOOGLE_MAPS_LANGUAGE=en-ZA
GOOGLE_ROUTE_MATRIX_ENABLED=true
DEFAULT_SEARCH_RADIUS_KM=20
DEFAULT_MAX_TRAVEL_MINUTES=45

PAYMENT_PROVIDER=disabled
PAYFAST_SANDBOX=true
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

TENANT_MONTHLY_PRICE=50
LANDLORD_MONTHLY_PRICE=100
LANDLORD_MAX_LISTINGS=25
SUBSCRIPTION_CURRENCY=ZAR

EMAIL_VERIFICATION_REQUIRED=false
ADMIN_2FA_REQUIRED=false
LISTING_EXPIRES_DAYS=30
SAVED_SEARCH_ALERTS_ENABLED=true
RUN_JOBS_INLINE=true
MAX_UPLOAD_MB=12
UPLOAD_STORAGE_BACKEND=local

# Reverse proxy / production hardening
PROXY_FIX_ENABLED=true
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
SESSION_COOKIE_SECURE=false
REMEMBER_COOKIE_SECURE=false
