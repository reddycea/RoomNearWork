# RNW environment
FLASK_APP=backend.app:create_app
FLASK_ENV=development
APP_NAME=RNW
APP_BASE_URL=http://localhost:5000
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# Database
DATABASE_URL=sqlite:///instance/rnw.sqlite3
# Production MySQL example:
# DATABASE_URL=mysql+pymysql://rnw:${MYSQL_PASSWORD}@db:3306/rnw

# Mail
MAIL_SERVER=localhost
MAIL_PORT=25
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@rnw.local
EMAIL_VERIFICATION_REQUIRED=false

# Cache / rate limiting
REDIS_URL=redis://redis:6379/0
CACHE_TYPE=SimpleCache
RATELIMIT_STORAGE_URI=memory://

# Uploads and logs
UPLOAD_FOLDER=backend/instance/uploads
MAX_CONTENT_LENGTH_MB=16
LOG_LEVEL=INFO
LOG_FILE=backend/instance/logs/rnw.log

# Billing
# Use disabled for local sandbox. Use payfast for SA production checkout.
PAYMENT_PROVIDER=disabled
PAYFAST_SANDBOX=true
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Docker database secrets
MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_DATABASE=rnw
MYSQL_USER=rnw
MYSQL_PASSWORD=change-db-password
