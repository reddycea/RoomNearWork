# Room Near Work - Render manual environment template
# Use this if you deploy manually instead of using render.yaml.

FLASK_ENV=production
FLASK_DEBUG=false
APP_BASE_URL=https://your-service.onrender.com
PYTHON_VERSION=3.12.4
PORT=10000

SECRET_KEY=generate-in-render-or-with-python-secrets
JWT_SECRET_KEY=generate-different-secret
DATABASE_URL=postgresql://user:password@host:5432/dbname
REDIS_URL=redis://render-keyvalue-private-url:6379
RATELIMIT_STORAGE_URI=redis://render-keyvalue-private-url:6379
UPLOAD_FOLDER_PATH=/var/data/uploads

GOOGLE_MAPS_API_KEY=your-server-side-google-key
GOOGLE_MAPS_BROWSER_KEY=your-browser-google-key
GOOGLE_MAPS_REGION=ZA
GOOGLE_MAPS_LANGUAGE=en-ZA
GOOGLE_ROUTE_MATRIX_ENABLED=true
DEFAULT_SEARCH_RADIUS_KM=20
DEFAULT_MAX_TRAVEL_MINUTES=45

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-app-password
MAIL_DEFAULT_SENDER=no-reply@roomnearwork.co.za

PAYMENT_PROVIDER=payfast
PAYFAST_SANDBOX=true
PAYFAST_MERCHANT_ID=your-payfast-merchant-id
PAYFAST_MERCHANT_KEY=your-payfast-merchant-key
PAYFAST_PASSPHRASE=your-payfast-passphrase

TENANT_MONTHLY_PRICE=50
LANDLORD_MONTHLY_PRICE=100
LANDLORD_MAX_LISTINGS=25
SUBSCRIPTION_CURRENCY=ZAR

EMAIL_VERIFICATION_REQUIRED=true
ADMIN_2FA_REQUIRED=true
LISTING_EXPIRES_DAYS=30
SAVED_SEARCH_ALERTS_ENABLED=true
RUN_JOBS_INLINE=false
MAX_UPLOAD_MB=12
UPLOAD_STORAGE_BACKEND=local

PROXY_FIX_ENABLED=true
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
SESSION_COOKIE_SECURE=true
REMEMBER_COOKIE_SECURE=true
LOG_LEVEL=INFO
LOG_FILE=/var/data/logs/rnw.log
